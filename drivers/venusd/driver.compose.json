    "batteries": ["INTERNAL"],
    "meterPowerImportedCapability": "meter_power.imported",
    "meterPowerExportedCapability": "meter_power.exported"
  },
  "class": "battery",
  "images": {
    "large": "/drivers/venusd/assets/images/large.png",
    "small": "/drivers/venusd/assets/images/small.png",
