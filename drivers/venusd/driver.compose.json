  "settings": [
    {
      "type": "group",
      "label": {
        "en": "Connection Settings"
      },
      "children": [
        {
          "id": "ip",
          "type": "text",
          "label": {
            "en": "IP Address"
          },
          "value": "192.168.1.100",
          "hint": {
            "en": "IP address of the Venus D (direct Modbus TCP) or your Modbus TCP-to-RS485 gateway (EW11, Waveshare). Some resellers market the Venus D as 'Duravolt'."
          }
        },
        {
          "id": "port",
          "type": "number",
          "label": {
            "en": "Port"
          },
          "value": 502,
          "min": 1,
          "max": 65535
        },
        {
          "id": "slave_id",
          "type": "number",
          "label": {
            "en": "Slave ID"
          },
          "value": 1,
          "min": 1,
          "max": 247
        },
        {
          "id": "poll_interval",
          "type": "number",
          "label": {
            "en": "Poll Interval (ms)"
          },
          "value": 5000,
          "min": 2000,
          "max": 60000
        },
        {
          "id": "connection_timeout",
          "type": "number",
          "label": {
            "en": "Connection Timeout (ms)",
            "nl": "Verbindingstimeout (ms)"
          },
          "hint": {
            "en": "Timeout for Modbus read/write operations. Increase if you have a slow or unstable connection",
            "nl": "Timeout voor Modbus lees/schrijf operaties. Verhoog bij trage of instabiele verbinding"
          },
          "value": 5000,
          "min": 1000,
          "max": 30000
        },
        {
          "id": "max_consecutive_errors",
          "type": "number",
          "label": {
            "en": "Max Errors Before Unavailable",
            "nl": "Max Fouten Voor Onbeschikbaar"
          },
          "hint": {
            "en": "Number of consecutive polling errors before marking device unavailable",
            "nl": "Aantal opeenvolgende polling fouten voordat apparaat onbeschikbaar wordt gemarkeerd"
          },
          "value": 3,
          "min": 1,
          "max": 10
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Device info" },
      "children": [
        {
          "id": "storage_capacity",
          "type": "label",
          "label": {
            "en": "Storage capacity",
            "nl": "Opslag capaciteit"
          },
          "value": "x.x kwh"
        },
        {
          "id": "device_name",
          "type": "label",
          "label": {
            "en": "Marstek device name",
            "nl": "Marstek apparaat naam"
          },
          "value": "xxx"
        },
        {
          "id": "firmware",
          "type": "label",
          "label": { "en": "Firmware" },
          "value": "xxx"
        }
      ]
    }
  ]
}
