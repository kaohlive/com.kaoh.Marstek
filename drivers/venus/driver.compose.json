  "settings": [
    {
      "type": "group",
      "label": {
        "en": "Connection Settings"
      },
      "children": [
        {
          "id": "ip",
          "type": "text",
          "label": {
            "en": "IP Address"
          },
          "value": "192.168.1.100",
          "hint": {
            "en": "IP address of the EW11 Modbus gateway"
          }
        },
        {
          "id": "port", 
          "type": "number",
          "label": {
            "en": "Port"
          },
          "value": 502,
          "min": 1,
          "max": 65535
        },
        {
          "id": "slave_id",
          "type": "number", 
          "label": {
            "en": "Slave ID"
          },
          "value": 1,
          "min": 1,
          "max": 247
        },
        {
          "id": "poll_interval",
          "type": "number",
          "label": {
            "en": "Poll Interval (ms)"
          },
          "value": 5000,
          "min": 1000,
          "max": 60000
        },
        {
          "id": "force_mode_delay",
          "type": "number",
          "label": {
            "en": "Force Mode Delay (ms)",
            "nl": "Gedwongen Modus Vertraging (ms)"
          },
          "hint": {
            "en": "Delay before confirming force mode change to allow battery to accept new state",
            "nl": "Vertraging voordat gedwongen modus wijziging wordt bevestigd, zodat batterij nieuwe status kan accepteren"
          },
          "value": 1000,
          "min": 0,
          "max": 10000
        },
        {
          "id": "connection_timeout",
          "type": "number",
          "label": {
            "en": "Connection Timeout (ms)",
            "nl": "Verbindingstimeout (ms)"
          },
          "hint": {
            "en": "Timeout for Modbus read/write operations. Increase if you have a slow or unstable connection",
            "nl": "Timeout voor Modbus lees/schrijf operaties. Verhoog bij trage of instabiele verbinding"
          },
          "value": 5000,
          "min": 1000,
          "max": 30000
        },
        {
          "id": "max_consecutive_errors",
          "type": "number",
          "label": {
            "en": "Max Errors Before Unavailable",
            "nl": "Max Fouten Voor Onbeschikbaar"
          },
          "hint": {
            "en": "Number of consecutive polling errors before marking device unavailable",
            "nl": "Aantal opeenvolgende polling fouten voordat apparaat onbeschikbaar wordt gemarkeerd"
          },
          "value": 3,
          "min": 1,
          "max": 10
        },
        {
          "id": "show_alarms",
          "type": "dropdown",
          "label": {
            "en": "Show fault alarms",
            "nl": "Toon fouten"
          },
          "hint": {
            "en": "Controls whether fault registers 36000/36100/36101 trigger user-visible warnings and flow cards. Register 36103 was removed in v1.5.6 because it produced constant false positives on firmware v149. If a future firmware causes spurious bits on the remaining registers, set to 'Never show' as an escape hatch.",
            "nl": "Bepaalt of foutregisters 36000/36100/36101 zichtbare waarschuwingen en flow cards triggeren. Register 36103 is verwijderd in v1.5.6 omdat het valse alarmen produceerde op firmware v149. Als een toekomstige firmware valse bits op de overige registers zet, kies dan 'Nooit tonen' als tijdelijke oplossing."
          },
          "value": "auto",
          "values": [
            { "id": "auto", "label": { "en": "Automatic (show real faults)", "nl": "Automatisch (toon echte fouten)" } },
            { "id": "always", "label": { "en": "Always show", "nl": "Altijd tonen" } },
            { "id": "never", "label": { "en": "Never show", "nl": "Nooit tonen" } }
          ]
        }
      ]
    },
    {
    "type": "group",
    "label": { "en": "Battery info" },
    "children": [
      {
        "id": "storage_capacity",
        "type": "label",
        "label": {
           "en": "Storage capability",
           "nl": "Opslag capacitijd"
        },
        "value": "x.x kwh"
      },
      {
        "id": "device_name",
        "type": "label",
        "label": { "en": "Marstek device name",
                   "nl": "Marstek apperaat naam"
                 },
        "value": "xxx"
      },
      {
        "id": "firmware",
        "type": "label",
        "label": { "en": "Firmware" },
        "value": "xxx"
      },
      {
        "id": "device_version",
        "type": "label",
        "label": {
          "en": "Device Version",
          "nl": "Apparaat Versie"
        },
        "value": "unknown"
      }
    ]
  },
  {
    "type": "group",
    "label": {
      "en": "Battery Protection Settings",
      "nl": "Batterij Bescherming Instellingen"
    },
    "children": [
      {
        "id": "charging_cutoff_soc",
        "type": "number",
        "label": {
          "en": "Charging Cutoff SOC (%)",
          "nl": "Laad Afkap SOC (%)"
        },
        "hint": {
          "en": "SOC level at which charging stops. Recommended range: 40-100%",
          "nl": "SOC niveau waarbij laden stopt. Aanbevolen bereik: 40-100%"
        },
        "value": 100,
        "min": 0,
        "max": 100,
        "units": "%"
      },
      {
        "id": "discharging_cutoff_soc",
        "type": "number",
        "label": {
          "en": "Discharging Cutoff SOC (%)",
          "nl": "Ontlaad Afkap SOC (%)"
        },
        "hint": {
          "en": "SOC reserve level below which discharging stops. Recommended range: 12-30%. WARNING: Setting this below 15% is not recommended as it may reduce battery lifespan.",
          "nl": "SOC reserve niveau waaronder ontladen stopt. Aanbevolen bereik: 12-30%. WAARSCHUWING: Instellen onder 15% wordt niet aanbevolen omdat dit de levensduur van de batterij kan verkorten."
        },
        "value": 15,
        "min": 0,
        "max": 100,
        "units": "%"
      }
    ]
  }
  ]
}