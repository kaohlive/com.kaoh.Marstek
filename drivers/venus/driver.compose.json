  },
  "settings": [
    {
      "type": "group",
      "label": {
        "en": "Connection Settings"
      },
      "children": [
        {
          "id": "ip",
          "type": "text",
          "label": {
            "en": "IP Address"
          },
          "value": "192.168.1.100",
          "hint": {
            "en": "IP address of the EW11 Modbus gateway"
          }
        },
        {
          "id": "port", 
          "type": "number",
          "label": {
            "en": "Port"
          },
          "value": 502,
          "min": 1,
          "max": 65535
        },
        {
          "id": "slave_id",
          "type": "number", 
          "label": {
            "en": "Slave ID"
          },
          "value": 1,
          "min": 1,
          "max": 247
        },
        {
          "id": "poll_interval",
          "type": "number",
          "label": {
            "en": "Poll Interval (ms)"
          },
          "hint": {
            "en": "Full state-read poll cycle. Cannot be set below 2000ms - the cycle itself takes ~1-2s of Modbus traffic and overlapping polls would cause read errors. Force-command recovery runs on a separate 1s fast-check loop independent of this setting."
          },
          "value": 5000,
          "min": 2000,
          "max": 60000
        },
        {
          "id": "force_mode_delay",
          "type": "number",
          "label": {
            "en": "Force Mode Delay (ms)",
            "nl": "Gedwongen Modus Vertraging (ms)"
          },
          "hint": {
            "en": "Delay before confirming force mode change to allow battery to accept new state",
            "nl": "Vertraging voordat gedwongen modus wijziging wordt bevestigd, zodat batterij nieuwe status kan accepteren"
          },
          "value": 1000,
          "min": 0,
          "max": 10000
        },
        {
          "id": "connection_timeout",
          "type": "number",
          "label": {
            "en": "Connection Timeout (ms)",
            "nl": "Verbindingstimeout (ms)"
          },
          "hint": {
            "en": "Timeout for Modbus read/write operations. Increase if you have a slow or unstable connection",
            "nl": "Timeout voor Modbus lees/schrijf operaties. Verhoog bij trage of instabiele verbinding"
          },
          "value": 5000,
          "min": 1000,
          "max": 30000
        },
        {
          "id": "max_consecutive_errors",
          "type": "number",
          "label": {
            "en": "Max Errors Before Unavailable",
            "nl": "Max Fouten Voor Onbeschikbaar"
          },
          "hint": {
            "en": "Number of consecutive polling errors before marking device unavailable",
            "nl": "Aantal opeenvolgende polling fouten voordat apparaat onbeschikbaar wordt gemarkeerd"
          },
          "value": 3,
          "min": 1,
          "max": 10
        },
        {
          "id": "enable_force_recovery",
          "type": "checkbox",
          "label": {
            "en": "Auto-recover force-command reverts",
            "nl": "Automatisch herstel van force-command reverts"
          },
          "hint": {
            "en": "When on, a fast-check loop watches register 42010 and re-asserts the force command immediately if the firmware reverts it (bounds 0W dips). Turn off if you experience Modbus connection instability - the recovery loop adds load to the bus that some Marstek firmware versions handle poorly. With this off the battery will still see periodic 0W dips when the firmware countdown expires, but the device connection is more stable.",
            "nl": "Als aan, controleert een snelle loop register 42010 en herstelt deze direct als de firmware de force-command laat vallen (begrenst 0W dips). Schakel uit als je Modbus verbindingsproblemen ervaart - de herstelloop voegt belasting toe aan de bus die sommige Marstek firmware versies slecht aankunnen. Met deze uit zal de batterij nog steeds periodieke 0W dips ervaren als de firmware-countdown afloopt, maar is de verbinding stabieler."
          },
          "value": true
        },
        {
          "id": "fast_check_interval",
          "type": "number",
          "label": {
            "en": "Fast-check interval (ms)",
            "nl": "Fast-check interval (ms)"
          },
          "hint": {
            "en": "How often the auto-recovery loop reads register 42010. Lower = faster recovery from firmware reverts but more Modbus traffic. Higher = less bus load but longer visible 0W dips. Try raising to 2000-5000ms if Auto-recovery is on but you still see occasional Modbus timeouts. Ignored when Auto-recovery is off.",
            "nl": "Hoe vaak de herstelloop register 42010 leest. Lager = sneller herstel van firmware reverts maar meer Modbus verkeer. Hoger = minder belasting maar langere zichtbare 0W dips. Probeer 2000-5000ms als Auto-recovery aan staat maar je nog steeds af en toe Modbus timeouts ziet. Wordt genegeerd wanneer Auto-recovery uit staat."
          },
          "value": 1000,
          "min": 500,
          "max": 30000
        }
      ]
    },
    {
    "type": "group",
    "label": { "en": "Battery info" },
    "children": [
      {
        "id": "storage_capacity",
        "type": "label",
        "label": {
           "en": "Storage capability",
           "nl": "Opslag capacitijd"
        },
        "value": "x.x kwh"
      },
      {
        "id": "device_name",
        "type": "label",
        "label": { "en": "Marstek device name",
                   "nl": "Marstek apperaat naam"
                 },
        "value": "xxx"
      },
      {
        "id": "firmware",
        "type": "label",
        "label": { "en": "Firmware" },
        "value": "xxx"
      },
      {
        "id": "device_version",
        "type": "label",
        "label": {
          "en": "Device Version",
          "nl": "Apparaat Versie"
        },
        "value": "unknown"
      }
    ]
  },
  {
    "type": "group",
    "label": {
      "en": "Battery Protection Settings",
      "nl": "Batterij Bescherming Instellingen"
    },
    "children": [
      {
        "id": "charging_cutoff_soc",
        "type": "number",
        "label": {
          "en": "Charging Cutoff SOC (%)",
          "nl": "Laad Afkap SOC (%)"
        },
        "hint": {
          "en": "SOC level at which charging stops. Recommended range: 40-100%",
          "nl": "SOC niveau waarbij laden stopt. Aanbevolen bereik: 40-100%"
        },
        "value": 100,
        "min": 0,
        "max": 100,
        "units": "%"
      },
      {
        "id": "discharging_cutoff_soc",
        "type": "number",
        "label": {
          "en": "Discharging Cutoff SOC (%)",
          "nl": "Ontlaad Afkap SOC (%)"
        },
        "hint": {
          "en": "SOC reserve level below which discharging stops. Recommended range: 12-30%. WARNING: Setting this below 15% is not recommended as it may reduce battery lifespan.",
          "nl": "SOC reserve niveau waaronder ontladen stopt. Aanbevolen bereik: 12-30%. WAARSCHUWING: Instellen onder 15% wordt niet aanbevolen omdat dit de levensduur van de batterij kan verkorten."
        },
        "value": 15,
        "min": 0,
        "max": 100,
        "units": "%"
      }
    ]
  }
  ]
}